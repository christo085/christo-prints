<!-- Featured Products -->
<section class="section">
  <div class="section-header">
    <h2>Popular Picks</h2>
    <p>Our most-loved products</p>
  </div>
  <div class="product-grid">
    {%- for product in products.items %}
    {%- if product.popular %}
    <div class="product-card">
      <a href="/products/{{ product.name | slug }}/" class="product-card-img-link" tabindex="-1" aria-hidden="true">
        <div class="product-card-img">
          <img src="/{{ product.image }}" alt="{{ product.name }}" loading="lazy">
          {%- if product.badge %}
          <span class="product-card-badge{% if product.badge == 'Trending' %} badge-trending{% endif %}">{{ product.badge }}</span>
          {%- endif %}
        </div>
      </a>
      <div class="product-card-body">
        <a href="/products/{{ product.name | slug }}/" class="product-card-title-link">
          <h3>{{ product.name }}</h3>
        </a>
        <p class="description">{{ product.description }}</p>
        <div class="product-card-footer">
          <span class="price">{{ product.price }}</span>
          <div class="btn-group">
            <a href="/products/{{ product.name | slug }}/" class="btn btn-secondary btn-small" aria-label="View {{ product.name }} details">Details</a>
            <button class="btn btn-primary btn-small btn-add-to-cart"
              data-name="{{ product.name }}" data-price="{{ product.price }}" data-type="product"
              onclick="Cart.addItem(this.dataset.name, this.dataset.price, this.dataset.type); Cart.flashAdded(this);"
              aria-label="Add {{ product.name }} to basket">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="9" y1="6" x2="15" y2="6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
    {%- endif %}
    {%- endfor %}
  </div>
  <div style="text-align:center; margin-top:36px;">
    <a href="/products/" class="btn btn-secondary">View All Products &#8594;</a>
  </div>
</section>

<!-- Product Marquee -->
{%- set marqueeItems = [] %}
{%- for p in products.items | activeOnly %}
  {%- if p.images and p.images.length > 0 %}
    {%- set marqueeItems = marqueeItems.concat([p]) %}
  {%- endif %}
{%- endfor %}
<div class="product-marquee" aria-hidden="true" id="productMarquee">
  <div class="product-marquee-track" id="marqueeTrack">
    {%- for p in marqueeItems %}
    <a href="/products/{{ p.name | slug }}/" class="product-marquee-item" tabindex="-1">
      <div class="product-marquee-img"><img src="/{{ p.image }}" alt="{{ p.name }}" loading="lazy"></div>
      <div class="product-marquee-label">{{ p.name }}</div>
    </a>
    {%- endfor %}
    {%- for p in marqueeItems %}
    <a href="/products/{{ p.name | slug }}/" class="product-marquee-item" tabindex="-1">
      <div class="product-marquee-img"><img src="/{{ p.image }}" alt="" loading="lazy"></div>
      <div class="product-marquee-label">{{ p.name }}</div>
    </a>
    {%- endfor %}
  </div>
</div>
<script>
(function () {
  var track = document.getElementById('marqueeTrack');
  if (!track) return;
  var pos = 0;
  var speed = 0.4;
  var dragging = false;
  var dragStartX = 0;
  var dragStartPos = 0;
  var halfWidth = 0;

  function getHalf() {
    halfWidth = track.scrollWidth / 2;
  }

  function tick() {
    if (!dragging) {
      pos += speed;
      if (pos >= halfWidth) pos -= halfWidth;
      track.style.transform = 'translateX(-' + pos + 'px)';
    }
    requestAnimationFrame(tick);
  }

  window.addEventListener('load', function () {
    getHalf();
    tick();
  });

  // Mouse drag
  track.addEventListener('mousedown', function (e) {
    dragging = true;
    dragStartX = e.clientX;
    dragStartPos = pos;
    track.classList.add('dragging');
    e.preventDefault();
  });

  document.addEventListener('mousemove', function (e) {
    if (!dragging) return;
    var delta = dragStartX - e.clientX;
    pos = ((dragStartPos + delta) % halfWidth + halfWidth) % halfWidth;
    track.style.transform = 'translateX(-' + pos + 'px)';
  });

  document.addEventListener('mouseup', function () {
    if (!dragging) return;
    dragging = false;
    track.classList.remove('dragging');
  });

  // Touch drag — direction-aware so vertical swipes still scroll the page
  var touchStartX = 0;
  var touchStartY = 0;
  var touchIntent = null; // 'drag' | 'scroll' | null

  track.addEventListener('touchstart', function (e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    dragStartPos = pos;
    touchIntent = null;
    dragging = false;
  }, { passive: true });

  document.addEventListener('touchmove', function (e) {
    if (touchIntent === 'scroll') return;

    var dx = touchStartX - e.touches[0].clientX;
    var dy = touchStartY - e.touches[0].clientY;

    // Wait for enough movement to determine intent
    if (touchIntent === null) {
      if (Math.abs(dx) < 5 && Math.abs(dy) < 5) return;
      touchIntent = Math.abs(dx) > Math.abs(dy) ? 'drag' : 'scroll';
      if (touchIntent === 'drag') {
        dragging = true;
        dragStartX = touchStartX;
        track.classList.add('dragging');
      }
    }

    if (touchIntent === 'drag') {
      e.preventDefault();
      var delta = touchStartX - e.touches[0].clientX;
      pos = ((dragStartPos + delta) % halfWidth + halfWidth) % halfWidth;
      track.style.transform = 'translateX(-' + pos + 'px)';
    }
  }, { passive: false });

  document.addEventListener('touchend', function () {
    if (dragging) {
      dragging = false;
      track.classList.remove('dragging');
    }
    touchIntent = null;
  });

  // Prevent click-through after drag
  var didDrag = false;
  track.addEventListener('mousedown', function () { didDrag = false; });
  document.addEventListener('mousemove', function (e) { if (dragging && Math.abs(e.movementX) > 2) didDrag = true; });
  track.addEventListener('click', function (e) { if (didDrag) e.preventDefault(); }, true);
})();
</script>

{%- set futureEvents = events.upcoming | filterPastEvents %}
{%- set activeSeasonal = events.seasonal | activeOnly %}
{%- set SEASONAL_BADGES = ["Easter", "Halloween", "Christmas", "Spring", "Other"] %}
{%- set firstSeasonalBadge = "" %}
{%- for item in activeSeasonal %}
  {%- if not firstSeasonalBadge and item.badge and item.badge in SEASONAL_BADGES %}
    {%- set firstSeasonalBadge = item.badge %}
  {%- endif %}
{%- endfor %}
{%- if futureEvents | length > 0 or activeSeasonal | length > 0 %}
<!-- Events & Seasonal Banner -->
<section class="section" style="padding-top: 0;">
  <div class="cta-banner events-banner">
    <span class="events-banner-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Events &amp; Seasonal
    </span>
    {%- if futureEvents | length > 0 %}
    <h2>{{ futureEvents[0].name }}</h2>
    <p>{{ futureEvents[0].date }}{%- if futureEvents[0].location %} &middot; {{ futureEvents[0].location }}{%- endif %}</p>
    {%- else %}
    <h2>Seasonal Specials Available</h2>
    <p>Limited edition prints for holidays and special occasions</p>
    {%- endif %}
    {%- if firstSeasonalBadge and futureEvents | length == 0 %}
    <a href="/events/?open={{ firstSeasonalBadge }}" class="btn btn-primary" style="margin-top: 8px;">Shop {{ firstSeasonalBadge }} Collection &#8594;</a>
    {%- else %}
    <a href="/events/" class="btn btn-primary" style="margin-top: 8px;">View Events &amp; Specials &#8594;</a>
    {%- endif %}
  </div>
</section>
{%- endif %}

