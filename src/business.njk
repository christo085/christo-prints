<!-- Form -->
<section class="section" style="padding-top: 0;">

  <div class="cart-success" id="bizSuccess" hidden>
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
      <polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <h2>Enquiry received!</h2>
    <p>Thanks for getting in touch. We'll review your brief and reach out within 1–2 working days.</p>
    <a href="/products/" class="btn btn-primary" style="margin-top: 16px;">Browse Products</a>
  </div>

  <div class="form-container" id="bizFormContainer">
    <div style="margin-bottom: 24px;">
      <h2 style="margin: 0 0 6px;">Send Us Your Brief</h2>
      <p style="color: var(--text-secondary); margin: 0;">Fill in as much detail as you can and we'll get back to you quickly.</p>
    </div>

    <form name="business-enquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/business/?success=true" id="bizForm">
      <input type="hidden" name="form-name" value="business-enquiry">
      <p class="visually-hidden"><label>Don't fill this in: <input name="bot-field"></label></p>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="name">Your Name <span style="color:var(--accent)">*</span></label>
          <input class="form-input" type="text" id="name" name="name" placeholder="Your name" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="company">Company / Organisation</label>
          <input class="form-input" type="text" id="company" name="company" placeholder="Business or school name">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="you@company.com">
        </div>
        <div class="form-group">
          <label class="form-label" for="phone">Phone</label>
          <input class="form-input" type="tel" id="phone" name="phone" placeholder="07xxx xxxxxx">
        </div>
      </div>
      <p class="form-hint">Please provide at least an email or phone number.</p>
      <p class="form-error" id="bizContactError">Please enter an email address or phone number so we can reach you.</p>

      <div class="form-group">
        <label class="form-label" for="project">What do you need printed? <span style="color:var(--accent)">*</span></label>
        <textarea class="form-textarea" id="project" name="project" placeholder="Describe your project — what it is, what it's for, any design files or references you have." required style="min-height: 130px;"></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="quantity">Quantity <span style="color:var(--accent)">*</span></label>
          <input class="form-input" type="number" id="quantity" name="quantity" min="1" placeholder="How many units?" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="deadline">Deadline</label>
          <input class="form-input" type="text" id="deadline" name="deadline" placeholder="When do you need them by?">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="budget">Budget (optional)</label>
        <input class="form-input" type="text" id="budget" name="budget" placeholder="Approximate budget, if you have one in mind">
      </div>

      <div class="form-group">
        <label class="form-label" for="notes">Anything else?</label>
        <textarea class="form-textarea" id="notes" name="notes" placeholder="Preferred colours, material, packaging, or any other details"></textarea>
      </div>

      <button type="submit" class="btn btn-primary btn-large">Send Enquiry</button>
    </form>
  </div>

</section>

<style>
.custom-steps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
@media (max-width: 768px) {
  .custom-steps-grid { grid-template-columns: 1fr; }
}
.custom-step-card { text-align: center; }
.custom-step-number {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--accent);
  margin: 0 auto 12px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--accent-dim);
  display: flex;
  align-items: center;
  justify-content: center;
}
</style>

<script>
(function () {
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('bizSuccess').hidden = false;
    document.getElementById('bizFormContainer').hidden = true;
    return;
  }

  var form = document.getElementById('bizForm');
  form.addEventListener('submit', function (e) {
    var email = document.getElementById('email').value.trim();
    var phone = document.getElementById('phone').value.trim();
    var errorEl = document.getElementById('bizContactError');
    if (!email && !phone) {
      e.preventDefault();
      errorEl.classList.add('visible');
      document.getElementById('email').focus();
      return;
    }
    errorEl.classList.remove('visible');
  });

  document.getElementById('email').addEventListener('input', function () {
    document.getElementById('bizContactError').classList.remove('visible');
  });
  document.getElementById('phone').addEventListener('input', function () {
    document.getElementById('bizContactError').classList.remove('visible');
  });
})();
</script>
