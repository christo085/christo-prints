<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="https://christoprints.com{{ page.url }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://christoprints.com{{ page.url }}">
  <meta property="og:locale" content="en_GB">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Christo's Prints",
    "description": "Affordable, high-quality 3D-printed fidget toys and practical gadgets. Printing happiness, one layer at a time.",
    "url": "https://christoprints.com",
    "email": "christo3dprints@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Edinburgh",
      "addressCountry": "GB"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "3D Printed Products",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Fidget Toys" } },
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Flexi Prints" } },
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Gadgets" } },
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Custom Prints" } }
      ]
    }
  }
  </script>
  <link rel="icon" type="image/png" href="/CPLogo.png">
  <link rel="stylesheet" href="/styles.css">
  <script src="/cart.js"></script>
</head>
<body>

  <!-- Navigation -->
  <header>
  <nav class="navbar" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
Christo's Prints
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="/"{% if activePage == "home" %} class="active"{% endif %}>Home</a></li>
        <li><a href="/products/"{% if activePage == "products" %} class="active"{% endif %}>Products</a></li>
        <li><a href="/bundles/"{% if activePage == "bundles" %} class="active"{% endif %}>Bundles</a></li>
        <li><a href="/colours/"{% if activePage == "colours" %} class="active"{% endif %}>Colours</a></li>
        <li><a href="/events/"{% if activePage == "events" %} class="active"{% endif %}>Events</a></li>
        <li><a href="/contact/"{% if activePage == "contact" %} class="active"{% endif %}>Contact</a></li>
        <li><a href="/reviews/"{% if activePage == "reviews" %} class="active"{% endif %}>Reviews</a></li>
        <li><a href="/custom/" class="nav-cta">Custom Print</a></li>
        <li>
          <a href="/basket/" class="nav-basket{% if activePage == "basket" %} active{% endif %}" aria-label="Basket">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <span class="cart-badge" id="cart-count" hidden>0</span>
          </a>
        </li>
      </ul>
      <div class="nav-right">
        <a href="/basket/" class="nav-basket-mobile" aria-label="Basket">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <span class="cart-badge" id="cart-count-mobile" hidden>0</span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="navLinks">&#9776;</button>
      </div>
    </div>
  </nav>
  </header>

  <main>
  {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div>
        <div class="footer-brand">Christo's Prints</div>
        <div class="footer-tagline">Printing Happiness</div>
        <a href="mailto:christo3dprints@gmail.com" class="footer-email">christo3dprints@gmail.com</a>
      </div>
      <ul class="footer-links">
        <li><a href="/products/">Products</a></li>
        <li><a href="/bundles/">Bundles</a></li>
        <li><a href="/colours/">Colours</a></li>
        <li><a href="/events/">Events</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/reviews/">Reviews</a></li>
        <li><a href="/terms/">Terms</a></li>
      </ul>
    </div>
    <div class="footer-credit">Made by <a href="https://forthdigital.uk" target="_blank" rel="noopener">Forth Digital</a></div>
  </footer>

  <!-- Back to Top -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
  <script>
    (function(){var btn=document.getElementById('backToTop');window.addEventListener('scroll',function(){btn.classList.toggle('visible',window.scrollY>400)},{passive:true});btn.addEventListener('click',function(){window.scrollTo({top:0,behavior:'smooth'})})})();
  </script>

  <script>
    document.addEventListener('error', function(e) {
      var img = e.target;
      if (img.tagName !== 'IMG' || img.dataset.placeholder) return;
      img.dataset.placeholder = '1';
      var ph = document.createElement('div');
      ph.className = 'img-placeholder';
      ph.innerHTML = '<div class="img-placeholder-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><span class="img-placeholder-text">Sorry, this image is unavailable</span><span class="img-placeholder-brand">Christo\'s Prints</span>';
      img.replaceWith(ph);
    }, true);
  </script>
  <script defer src="/nav.js"></script>
  <!-- WhatsApp floating button -->
  <style>
    #wa-btn{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;align-items:center;gap:0;cursor:pointer;text-decoration:none}
    #wa-bubble{background:#25D366;width:58px;height:58px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.45);transition:transform .2s,box-shadow .2s;flex-shrink:0;position:relative}
    #wa-btn:hover #wa-bubble{transform:scale(1.08);box-shadow:0 6px 28px rgba(37,211,102,.6)}
    #wa-bubble::before{content:'';position:absolute;width:58px;height:58px;border-radius:50%;background:rgba(37,211,102,.25);animation:waPulse 2s ease-out infinite}
    @keyframes waPulse{0%{transform:scale(1);opacity:1}100%{transform:scale(1.7);opacity:0}}
    #wa-label{background:#25D366;color:#fff;font-family:inherit;font-size:.82rem;font-weight:700;padding:8px 14px 8px 18px;border-radius:30px 0 0 30px;margin-right:-6px;white-space:nowrap;box-shadow:0 2px 10px rgba(37,211,102,.3);opacity:0;transform:translateX(10px);transition:opacity .25s,transform .25s;pointer-events:none}
    #wa-btn:hover #wa-label{opacity:1;transform:translateX(0)}
  </style>
  <a id="wa-btn" href="https://wa.me/447435976773?text=Hi%20Christo!%20I%20found%20your%20website%20and%20I%27d%20like%20to%20order%20%F0%9F%96%A8%EF%B8%8F" target="_blank" rel="noopener">
    <span id="wa-label">Order on WhatsApp</span>
    <div id="wa-bubble">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </div>
  </a>
</body>
</html>
