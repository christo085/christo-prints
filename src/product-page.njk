---
pagination:
  data: products.items
  size: 1
  alias: product
eleventyComputed:
  title: "{{ product.name }} - Christo's Prints"
  description: "{{ product.description }}"
layout: base.njk
activePage: products
permalink: "/products/{{ product.name | slug }}/"
---

<div class="page-header">
  <a href="/products/" class="back-link">&#8592; All Products</a>
  <h1>{{ product.name }}</h1>
  {% if product.badge %}
  <span class="product-page-badge{% if product.badge == 'Trending' %} badge-trending{% endif %}">{{ product.badge }}</span>
  {% elif product.dateAdded %}
  <span class="product-page-badge badge-new" data-added="{{ product.dateAdded }}">New</span>
  <script>
  (function(){var b=document.querySelector('.product-page-badge.badge-new');if(b){var d=new Date(b.dataset.added);if(!isNaN(d)&&Date.now()-d>30*86400000)b.style.display='none';}})();
  </script>
  {% endif %}
</div>

<section class="section" style="padding-top: 0;">
  <div class="product-page-grid">

    <!-- Image Gallery -->
    <div class="product-page-gallery">
      {%- set allImages = [] %}
      {%- if product.images and product.images.length > 0 %}
        {%- for img in product.images %}
          {%- set allImages = allImages.concat([img.image]) %}
        {%- endfor %}
      {%- else %}
        {%- set allImages = [product.image] %}
      {%- endif %}
      <div class="gallery-main">
        <img src="/{{ allImages[0] }}" alt="{{ product.name }}" id="galleryMain" loading="eager">
      </div>
      {% if allImages.length > 1 %}
      <div class="gallery-thumbs">
        {% for img in allImages %}
        <button class="gallery-thumb{% if loop.index == 1 %} active{% endif %}" onclick="setGallery('/{{ img }}', this, {{ loop.index0 }})" type="button" aria-label="View photo {{ loop.index }}">
          <img src="/{{ img }}" alt="{{ product.name }} photo {{ loop.index }}" loading="lazy">
        </button>
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <!-- Product Info -->
    <div class="product-page-info">
      <div class="product-page-price">{{ product.price }}</div>
      <p class="product-page-desc">{{ product.description }}</p>

      <!-- Colours -->
      <div class="product-page-colours">
        <button class="colours-toggle" type="button" aria-expanded="false" onclick="this.setAttribute('aria-expanded', this.nextElementSibling.hidden ? 'true' : 'false'); this.nextElementSibling.hidden = !this.nextElementSibling.hidden;">
          {% if product.colours %}
          <span>Only available in: {{ product.coloursLabel if product.coloursLabel else product.colours | join(", ") }}</span>
          {% else %}
          <span>All colours available</span>
          {% endif %}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="colours-toggle-icon"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="colours-body" hidden>
          {% if product.colours %}
          <p class="colours-note">This item is only available in {{ product.coloursLabel if product.coloursLabel else "the following colours" }}.</p>
          <div class="product-colours-swatches">
            {% set allColours = colours.standard.concat(colours.special) %}
            {% for colour in allColours %}
              {% if colour.name in product.colours %}
              <div class="product-colour-dot" title="{{ colour.name }}" style="background: {{ colour.hex }};"></div>
              {% endif %}
            {% endfor %}
          </div>
          {% else %}
          <p class="colours-note">This item can be printed in any colour — pick your preference in the basket, or leave as "No preference" and we'll choose for you.</p>
          {% set allColours = [] | resolveProductColours(colours) %}
          <div class="product-colours-swatches">
            {% for colour in allColours %}
            <div class="product-colour-dot" title="{{ colour.name }}" style="background: {{ colour.hex }};"></div>
            {% endfor %}
          </div>
          <a href="/colours/" class="colours-see-all">See all colours in detail &#8594;</a>
          {% endif %}
        </div>
      </div>

      <!-- Add to Cart / Buy Now -->
      {%- if product.lowStock %}
      <div class="low-stock-notice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Only a few left — order soon!
      </div>
      {%- endif %}
      {%- if product.active == false %}
      <div class="orders-paused-notice" style="margin-top: 16px; font-size: 0.95rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        This is a seasonal product — check back next Easter!
      </div>
      <a href="/products/" class="btn btn-secondary btn-large" style="margin-top: 12px;">Browse All Products</a>
      {%- else %}
      <div class="product-page-actions">
        <div class="buynow-options">
          <div class="form-group">
            <label class="form-label" for="buyNowColour">Colour</label>
            <select class="form-input" id="buyNowColour">
              {% set colourList = product.colours if product.colours else colours.dropdownOptions %}
              {% for opt in colourList %}
              <option value="{{ opt }}">{{ opt }}{% if opt in colours.lowStock %} (Running Low){% endif %}</option>
              {% endfor %}
            </select>
          </div>
          <div id="buyNowExtras" style="display:none;">
            <div class="form-group">
              <label class="form-label" for="buyNowName">Name (optional)</label>
              <input class="form-input" type="text" id="buyNowName" placeholder="Your name">
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="buyNowEmail">Email (optional)</label>
                <input class="form-input" type="email" id="buyNowEmail" placeholder="you@example.com">
              </div>
              <div class="form-group">
                <label class="form-label" for="buyNowPhone">Phone (optional)</label>
                <input class="form-input" type="tel" id="buyNowPhone" placeholder="07xxx xxxxxx">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="buyNowNotes">Notes (optional)</label>
              <textarea class="form-textarea" id="buyNowNotes" placeholder="Any special requests?" rows="2"></textarea>
            </div>
          </div>
        </div>
        <div class="buynow-buttons">
          {%- if notices.pauseOrders.enabled %}
          <div class="orders-paused-notice">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Orders are currently paused — check back soon!
          </div>
          <button class="btn btn-secondary btn-large" disabled>Add to Basket</button>
          <button class="btn btn-primary btn-large" disabled>Buy Now — {{ product.price }}</button>
          {%- else %}
          <button class="btn btn-secondary btn-large btn-add-to-cart"
            data-name="{{ product.name }}" data-price="{{ product.price }}" data-type="product"
            onclick="Cart.addItem(this.dataset.name, this.dataset.price, this.dataset.type); Cart.flashAdded(this);"
            aria-label="Add {{ product.name }} to basket">
            Add to Basket
          </button>
          <button class="btn btn-primary btn-large" id="buyNowBtn" onclick="buyNow()">
            Buy Now — {{ product.price }}
          </button>
          {%- endif %}
        </div>
      </div>
      {%- endif %}
      <p class="form-error" id="buyNowError" style="margin-top:8px;"></p>

      <button class="share-btn" onclick="shareProduct()" type="button" aria-label="Share this product">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        <span id="shareBtnText">Share</span>
      </button>
    </div>

  </div>
</section>

{%- set related = [] %}
{%- for p in products.items %}
  {%- if p.name != product.name and p.category == product.category and related.length < 3 %}
    {%- set related = related.concat([p]) %}
  {%- endif %}
{%- endfor %}
{%- if related.length > 0 %}
<!-- You might also like -->
<section class="section" style="padding-top: 0;">
  <div class="section-header">
    <h2>You might also like</h2>
  </div>
  <div class="product-grid product-grid--centered">
    {%- for p in related %}
    <div class="product-card">
      <a href="/products/{{ p.name | slug }}/" class="product-card-img-link" tabindex="-1" aria-hidden="true">
        <div class="product-card-img">
          <img src="/{{ p.image }}" alt="{{ p.name }}" loading="lazy">
          {%- if p.badge %}
          <span class="product-card-badge{% if p.badge == 'Trending' %} badge-trending{% endif %}">{{ p.badge }}</span>
          {%- endif %}
        </div>
      </a>
      <div class="product-card-body">
        <a href="/products/{{ p.name | slug }}/" class="product-card-title-link"><h3>{{ p.name }}</h3></a>
        <p class="description">{{ p.description }}</p>
        <div class="product-card-footer">
          <span class="price">{{ p.price }}</span>
          <div class="btn-group">
            <a href="/products/{{ p.name | slug }}/" class="btn btn-secondary btn-small" aria-label="View {{ p.name }} details">Details</a>
            <button class="btn btn-primary btn-small btn-add-to-cart"
              data-name="{{ p.name }}" data-price="{{ p.price }}" data-type="product"
              onclick="Cart.addItem(this.dataset.name, this.dataset.price, this.dataset.type); Cart.flashAdded(this);"
              aria-label="Add {{ p.name }} to basket">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="9" y1="6" x2="15" y2="6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
    {%- endfor %}
  </div>
</section>
{%- endif %}

<!-- CTA -->
<section class="section" style="padding-top: 0;">
  <div class="cta-banner">
    <h2>Want something different?</h2>
    <p>Request a custom print in any colour, size, or design.</p>
    <a href="/custom/" class="btn btn-primary">Request Custom Print &#8594;</a>
  </div>
</section>


<script>
async function shareProduct() {
  var url = 'https://christoprints.com/products/{{ product.name | slug }}/';
  var title = '{{ product.name }} — Christo\'s Prints';
  var text = '{{ product.name }} — {{ product.price }} 🖨️\n{{ product.description }}\n\n' + url;
  var btnText = document.getElementById('shareBtnText');

  if (navigator.share) {
    try {
      await navigator.share({ title: title, text: text, url: url });
    } catch (e) {}
    return;
  }
  try {
    await navigator.clipboard.writeText(text);
    btnText.textContent = '✓ Copied!';
    setTimeout(function () { btnText.textContent = 'Share'; }, 2500);
  } catch (e) {
    btnText.textContent = 'Share';
  }
}

var LB_IMAGES = [{% for img in allImages %}'/{{ img }}'{% if not loop.last %},{% endif %}{% endfor %}];
var currentGalleryIndex = 0;

function setGallery(src, btn, index) {
  document.getElementById('galleryMain').src = src;
  document.querySelectorAll('.gallery-thumb').forEach(function(t) { t.classList.remove('active'); });
  btn.classList.add('active');
  currentGalleryIndex = index || 0;
}


// Reset Buy Now button if user navigates back from payment without paying
window.addEventListener('pageshow', function (e) {
  if (e.persisted) {
    var btn = document.getElementById('buyNowBtn');
    if (btn && btn.disabled) {
      btn.disabled = false;
      btn.textContent = 'Confirm & Pay — {{ product.price }}';
    }
  }
});


async function buyNow() {
  var extras = document.getElementById('buyNowExtras');
  var btn = document.getElementById('buyNowBtn');
  var errEl = document.getElementById('buyNowError');

  // First click: reveal the extra fields
  if (extras.style.display === 'none') {
    extras.style.display = 'block';
    btn.textContent = 'Confirm & Pay — {{ product.price }}';
    extras.querySelector('#buyNowName').focus();
    return;
  }

  var colour = document.getElementById('buyNowColour').value;
  var notes = document.getElementById('buyNowNotes').value.trim();
  btn.disabled = true;
  btn.textContent = 'Redirecting…';
  errEl.classList.remove('visible');

  var itemPrice = parseFloat('{{ product.price }}'.replace('£', '')) || 0;
  var cardFee = Math.round((itemPrice * 0.014 + 0.25) * 100) / 100;

  var orderData = {
    items: [{ id: '{{ product.name | slug }}', name: '{{ product.name }}', price: '{{ product.price }}', qty: 1, colour: colour, type: 'product' }],
    name: document.getElementById('buyNowName').value.trim(),
    email: document.getElementById('buyNowEmail').value.trim(),
    phone: document.getElementById('buyNowPhone').value.trim(),
    notes: notes,
    cardFee: cardFee
  };

  try {
    var res = await fetch('/.netlify/functions/create-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(orderData)
    });
    var data = await res.json();
    if (!res.ok || !data.url) throw new Error(data.error || 'Could not start payment');
    sessionStorage.setItem('lastOrder', JSON.stringify(orderData));
    window.location.href = data.url;
  } catch (err) {
    btn.disabled = false;
    btn.textContent = 'Confirm & Pay — {{ product.price }}';
    errEl.textContent = 'Error: ' + err.message;
    errEl.classList.add('visible');
  }
}
</script>

