---
pagination:
  data: products.items
  size: 1
  alias: product
eleventyComputed:
  title: "{{ product.name }} - Christo's Prints"
  description: "{{ product.description }}"
layout: base.njk
activePage: products
permalink: "/products/{{ product.name | slug }}/"
---

<div class="page-header">
  <a href="/products/" class="back-link">&#8592; All Products</a>
  <h1>{{ product.name }}</h1>
  {% if product.badge %}
  <span class="product-page-badge">{{ product.badge }}</span>
  {% endif %}
</div>

<section class="section" style="padding-top: 0;">
  <div class="product-page-grid">

    <!-- Image Gallery -->
    <div class="product-page-gallery">
      {% set allImages = product.images if product.images else [product.image] %}
      <div class="gallery-main">
        <img src="/{{ allImages[0] }}" alt="{{ product.name }}" id="galleryMain" loading="eager">
      </div>
      {% if allImages.length > 1 %}
      <div class="gallery-thumbs">
        {% for img in allImages %}
        <button class="gallery-thumb{% if loop.index == 1 %} active{% endif %}" onclick="setGallery('/{{ img }}', this)" type="button" aria-label="View photo {{ loop.index }}">
          <img src="/{{ img }}" alt="{{ product.name }} photo {{ loop.index }}" loading="lazy">
        </button>
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <!-- Product Info -->
    <div class="product-page-info">
      <div class="product-page-price">{{ product.price }}</div>
      <p class="product-page-desc">{{ product.description }}</p>

      <!-- Colours -->
      <div class="product-page-colours">
        <h3>All colours available</h3>
        <p class="colours-note">This item can be printed in any colour — pick your preference in the basket, or leave as "No preference" and we'll choose for you.</p>
        {% set allColours = [] | resolveProductColours(colours) %}
        <div class="product-colours-swatches">
          {% for colour in allColours %}
          <div class="product-colour-dot" title="{{ colour.name }}" style="background: {{ colour.hex }};"></div>
          {% endfor %}
        </div>
        <div class="product-colours-names">
          {% for colour in allColours %}
          <span class="colour-chip">{{ colour.name }}</span>
          {% endfor %}
        </div>
        <a href="/colours/" class="colours-see-all">See all colours in detail &#8594;</a>
      </div>

      <!-- Add to Cart / Buy Now -->
      <div class="product-page-actions">
        <button class="btn btn-secondary btn-large btn-add-to-cart"
          data-name="{{ product.name }}" data-price="{{ product.price }}" data-type="product"
          onclick="Cart.addItem(this.dataset.name, this.dataset.price, this.dataset.type); Cart.flashAdded(this);"
          aria-label="Add {{ product.name }} to basket">
          Add to Basket
        </button>
        <button class="btn btn-primary btn-large" id="buyNowBtn" onclick="buyNow()">
          Buy Now — {{ product.price }}
        </button>
      </div>
      <p class="form-error" id="buyNowError" style="margin-top:8px;"></p>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="section" style="padding-top: 0;">
  <div class="cta-banner">
    <h2>Want something different?</h2>
    <p>Request a custom print in any colour, size, or design.</p>
    <a href="/custom/" class="btn btn-primary">Request Custom Print &#8594;</a>
  </div>
</section>

<script>
function setGallery(src, btn) {
  document.getElementById('galleryMain').src = src;
  document.querySelectorAll('.gallery-thumb').forEach(function(t) { t.classList.remove('active'); });
  btn.classList.add('active');
}

async function buyNow() {
  var btn = document.getElementById('buyNowBtn');
  var errEl = document.getElementById('buyNowError');
  btn.disabled = true;
  btn.textContent = 'Redirecting…';
  errEl.classList.remove('visible');

  try {
    var res = await fetch('/.netlify/functions/create-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items: [{ id: '{{ product.name | slug }}', name: '{{ product.name }}', price: '{{ product.price }}', qty: 1, colour: 'No preference', type: 'product' }],
        name: '', email: '', phone: '', notes: ''
      })
    });
    var data = await res.json();
    if (!res.ok || !data.url) throw new Error(data.error || 'Could not start payment');
    window.location.href = data.url;
  } catch (err) {
    btn.disabled = false;
    btn.textContent = 'Buy Now — {{ product.price }}';
    errEl.textContent = 'Error: ' + err.message;
    errEl.classList.add('visible');
  }
}
</script>
