---
layout: base.njk
title: "Basket - Christo's Prints"
description: "Review your basket and place an order from Christo's Prints."
activePage: basket
permalink: /basket/
---

<!-- Page Header -->
<div class="page-header">
  <h1>Your Basket</h1>
  <p>Review your items and place your order</p>
</div>

<section class="section" style="padding-top: 0;">

  <!-- Empty State -->
  <div class="cart-empty" id="cartEmpty" hidden>
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    <h2>Your basket is empty</h2>
    <p>Add some items and come back here to check out.</p>
    <a href="/products/" class="btn btn-primary" style="margin-top: 16px;">Browse Products</a>
  </div>

  <!-- Cart Items -->
  <div id="cartWrapper" hidden>
    <div id="cartItems"></div>
    <div class="cart-total" id="cartTotal"></div>

    <!-- Coupon code -->
    <div class="coupon-row" id="couponRow">
      <div class="coupon-input-row" id="couponInputRow">
        <input class="form-input coupon-input" type="text" id="couponCode" placeholder="Discount code" autocomplete="off" autocapitalize="characters">
        <button type="button" class="btn btn-secondary" onclick="applyCoupon()">Apply</button>
      </div>
      <p class="coupon-error" id="couponError"></p>
      <div class="coupon-applied" id="couponApplied">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span id="couponAppliedText"></span>
        <button type="button" class="coupon-remove" onclick="removeCoupon()" aria-label="Remove coupon">&times;</button>
      </div>
      <div class="coupon-reason-row" id="couponReasonRow" style="display:none;">
        <label class="form-label" for="couponReason">Which item from your previous order was damaged? <span style="color:var(--accent)">*</span></label>
        <input class="form-input" type="text" id="couponReason" placeholder="e.g. Infinity Cube, ordered last week" maxlength="200" autocomplete="off">
        <p class="coupon-error" id="couponReasonError"></p>
      </div>
    </div>

    <!-- Large order banner -->
    <div class="bulk-order-banner" id="bulkOrderBanner" style="display:none;">
      <div class="bulk-order-banner-inner">
        <div class="bulk-order-banner-text">
          <strong>That's a big one! 🎉</strong>
          <p>For larger orders it's much easier to sort things out directly — we can make sure everything's perfect for you.</p>
        </div>
        <div class="bulk-order-banner-actions">
          <a id="bulkWhatsApp" href="#" target="_blank" rel="noopener" class="btn btn-primary">Message on WhatsApp</a>
          <a href="/contact/" class="btn btn-secondary">Get in touch</a>
        </div>
      </div>
    </div>

    <div class="cart-divider"></div>
    <h3 class="cart-section-title">Your Details</h3>

    <div class="form-container">
      <div class="form-group">
        <label class="form-label" for="name">Name</label>
        <input class="form-input" type="text" id="name" placeholder="Your name" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" placeholder="you@example.com">
        </div>
        <div class="form-group">
          <label class="form-label" for="phone">Phone</label>
          <input class="form-input" type="tel" id="phone" placeholder="07xxx xxxxxx">
        </div>
      </div>
      <p class="form-hint">Please provide at least an email or phone number.</p>
      <p class="form-error" id="contactError">Please enter an email address or phone number so we can reach you.</p>

      <div class="form-group">
        <label class="form-label" for="notes">Notes</label>
        <textarea class="form-textarea" id="notes" placeholder="Anything else you'd like us to know (e.g. custom name for keychains, colour preferences)"></textarea>
      </div>

      <div class="checkout-buttons">
        <button type="button" class="btn btn-primary btn-large" id="payBtn" onclick="startCheckout()">
          Pay with Card
        </button>
        <button type="button" class="btn btn-secondary btn-large" id="payAtCollectionBtn" onclick="payAtDelivery()">
          Pay at Collection / Delivery
        </button>
      </div>
      <p class="bulk-card-blocked" id="bulkCardBlocked" style="display:none;">Card payment unavailable for large orders — use the options above or pay at collection.</p>
      <p class="form-error" id="payError"></p>
      <p class="checkout-secure-note" id="squareNote">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Card payments secured by Square · <span style="opacity:0.75;">A small processing fee (1.4% + 25p) applies to card payments</span>
      </p>

      <!-- Hidden Netlify form for pay-at-delivery -->
      <form name="basket-order" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="deliveryForm" action="/success/" hidden>
        <input type="hidden" name="form-name" value="basket-order">
        <input type="hidden" name="bot-field">
        <input type="hidden" name="customer-name" id="deliveryName">
        <input type="hidden" name="email" id="deliveryEmail">
        <input type="hidden" name="phone" id="deliveryPhone">
        <input type="hidden" name="notes" id="deliveryNotes">
        <input type="hidden" name="cart-items" id="deliveryItems">
        <input type="hidden" name="payment" value="Pay at collection/delivery">
        <input type="hidden" name="discount-code" id="deliveryDiscount">
      </form>
    </div>
  </div>

</section>

<script>
(function () {
  var COLOURS = {{ colours.dropdownOptions | dump | safe }};
  var LOW_STOCK = {{ colours.lowStock | dump | safe }};
  var COUPONS = {{ coupons.items | dump | safe }};
  var appliedCoupon = null;
  var cardFeeAmount = 0;

  // Restore saved details
  var DETAILS_KEY = 'christoDetails';
  var COUPON_KEY = 'christoCoupon';
  function saveDetails() {
    try {
      localStorage.setItem(DETAILS_KEY, JSON.stringify({
        name: document.getElementById('name').value,
        email: document.getElementById('email').value,
        phone: document.getElementById('phone').value,
        notes: document.getElementById('notes').value
      }));
    } catch(e) {}
  }
  function loadDetails() {
    try {
      var saved = JSON.parse(localStorage.getItem(DETAILS_KEY));
      if (!saved) return;
      if (saved.name)  document.getElementById('name').value  = saved.name;
      if (saved.email) document.getElementById('email').value = saved.email;
      if (saved.phone) document.getElementById('phone').value = saved.phone;
      if (saved.notes) document.getElementById('notes').value = saved.notes;
    } catch(e) {}
  }
  ['name','email','phone','notes'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', saveDetails);
  });

  function render() {
    var items = Cart.getItems();
    var empty = document.getElementById('cartEmpty');
    var wrapper = document.getElementById('cartWrapper');
    var container = document.getElementById('cartItems');

    if (items.length === 0) {
      empty.hidden = false;
      wrapper.hidden = true;
      return;
    }
    empty.hidden = true;
    wrapper.hidden = false;

    function renderItem(item, hideRemove) {
      var isPresetColour = item.type === 'bundle';
      var isKeychain = item.name === 'Name Keychain';
      var colourHtml;

      if (isPresetColour) {
        colourHtml = '<div class="cart-colour-note">Colour is pre-set. Add custom colour requests in notes below.</div>';
      } else {
        var colourOptions = COLOURS.map(function (c) {
          var label = c + (LOW_STOCK.indexOf(c) !== -1 ? ' (Running Low)' : '');
          return '<option value="' + c + '"' + (item.colour === c ? ' selected' : '') + '>' + label + '</option>';
        }).join('');
        colourHtml = '<select class="form-input form-input-sm" onchange="Cart.updateColour(\'' + item.id + '\', this.value)">' + colourOptions + '</select>';
      }

      if (isKeychain) {
        var nameVal = item.keychainName || '';
        var estPrice = Cart.keychainPrice(nameVal);
        return '<div class="cart-item cart-item-keychain" data-id="' + item.id + '">' +
          '<div class="cart-item-info">' +
            '<span class="cart-item-name">Name Keychain</span>' +
            '<span class="cart-item-price">£1.00+</span>' +
          '</div>' +
          '<div class="cart-keychain-row">' +
            '<input type="text" class="form-input form-input-sm" placeholder="Enter name" value="' + nameVal.replace(/"/g, '&quot;') + '" ' +
              'oninput="handleKeychainInput(\'' + item.id + '\', this)" maxlength="15">' +
            '<span class="cart-keychain-estimate" id="keychain-est-' + item.id + '">Est: ' + estPrice + '</span>' +
          '</div>' +
          '<div class="cart-item-controls">' +
            colourHtml +
            (hideRemove ? '' : '<button type="button" class="cart-item-remove" onclick="Cart.removeItem(\'' + item.id + '\'); basketRender();" aria-label="Remove">&times;</button>') +
          '</div>' +
        '</div>';
      }

      return '<div class="cart-item" data-id="' + item.id + '">' +
        '<div class="cart-item-info">' +
          '<span class="cart-item-name">' + item.name + '</span>' +
          '<span class="cart-item-price">' + item.price + '</span>' +
        '</div>' +
        '<div class="cart-item-controls">' +
          colourHtml +
          (hideRemove ? '' :
            '<div class="btn-qty-group">' +
              '<button type="button" class="btn-qty" onclick="Cart.updateQty(\'' + item.id + '\', -1); basketRender();">&#8722;</button>' +
              '<span class="btn-qty-count">' + item.qty + '</span>' +
              '<button type="button" class="btn-qty" onclick="Cart.updateQty(\'' + item.id + '\', 1); basketRender();">+</button>' +
            '</div>' +
            '<button type="button" class="cart-item-remove" onclick="Cart.removeItem(\'' + item.id + '\'); basketRender();" aria-label="Remove">&times;</button>'
          ) +
        '</div>' +
      '</div>';
    }

    // Separate bundle items (id starts with 'bndl-') from regular items
    var bundleGroups = {};
    var regularItems = [];
    items.forEach(function (item) {
      var m = item.id.match(/^(bndl-\d+)-\d+$/);
      if (m) {
        var key = m[1];
        if (!bundleGroups[key]) bundleGroups[key] = [];
        bundleGroups[key].push(item);
      } else {
        regularItems.push(item);
      }
    });

    var html = regularItems.map(function(item, idx) { return renderItem(item, idx !== 0); }).join('');

    Object.keys(bundleGroups).forEach(function (key, idx) {
      var isTopBundle = regularItems.length === 0 && idx === 0;
      var groupItems = bundleGroups[key];
      var bundleTotal = groupItems.reduce(function (s, i) {
        return s + (parseFloat((i.price || '0').replace('£', '')) || 0) * i.qty;
      }, 0);
      var bundleIds = groupItems.map(function(i) { return '\'' + i.id + '\''; }).join(',');
      html += '<div class="cart-bundle-group">' +
        '<div class="cart-bundle-header">' +
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>' +
          '<span>Custom Bundle</span>' +
          '<span class="cart-bundle-total">£' + bundleTotal.toFixed(2) + '</span>' +
          (isTopBundle ? '<button type="button" class="cart-bundle-remove" onclick="[' + bundleIds + '].forEach(function(id){Cart.removeItem(id);}); basketRender();" aria-label="Remove bundle">&times; Remove</button>' : '') +
        '</div>' +
        groupItems.map(function(i) { return renderItem(i, true); }).join('') +
      '</div>';
    });

    container.innerHTML = html;

    var hasKeychain = items.some(function (i) { return i.name === 'Name Keychain'; });
    if (hasKeychain) {
      container.innerHTML += '<button type="button" class="btn btn-secondary btn-add-keychain" onclick="Cart.addItem(\'Name Keychain\', \'£1.00+\', \'product\'); basketRender();">+ Add another keychain</button>';
    }

    renderTotal();
  }

  function renderTotal() {
    var subtotal = Cart.getTotal();
    var discount = 0;
    if (appliedCoupon) {
      if (appliedCoupon.type === 'percentage') {
        discount = subtotal * (appliedCoupon.value / 100);
      } else {
        discount = Math.min(appliedCoupon.value, subtotal);
      }
    }
    var finalTotal = Math.max(0, subtotal - discount);

    // Large order check: over £30 OR over 20 total items
    var totalQty = Cart.getItems().reduce(function(s, i) { return s + i.qty; }, 0);
    var isBulk = finalTotal > 30 || totalQty > 20;

    // Card fee: 1.4% + 25p (added to Square order only, not shown in basket)
    cardFeeAmount = isBulk ? 0 : Math.round((finalTotal * 0.014 + 0.25) * 100) / 100;

    var html = '';
    if (appliedCoupon) {
      html += '<div class="cart-total-row cart-subtotal-row"><span>Subtotal</span><span>£' + subtotal.toFixed(2) + '</span></div>';
      html += '<div class="cart-total-row cart-discount-row"><span>' + appliedCoupon.description + '</span><span>−£' + discount.toFixed(2) + '</span></div>';
    }
    html += '<div class="cart-total-row"><span>Estimated Total</span><span class="cart-total-price">£' + finalTotal.toFixed(2) + '</span></div>';
    document.getElementById('cartTotal').innerHTML = html;
    var payBtn = document.getElementById('payBtn');
    var payAtBtn = document.getElementById('payAtCollectionBtn');
    var banner = document.getElementById('bulkOrderBanner');
    var blocked = document.getElementById('bulkCardBlocked');
    var squareNote = document.getElementById('squareNote');
    payBtn.disabled = isBulk;
    banner.style.display = isBulk ? 'block' : 'none';
    blocked.style.display = isBulk ? 'block' : 'none';
    squareNote.style.display = isBulk ? 'none' : '';
    if (isBulk) {
      payAtBtn.classList.remove('btn-secondary');
      payAtBtn.classList.add('btn-primary');
    } else {
      payAtBtn.classList.remove('btn-primary');
      payAtBtn.classList.add('btn-secondary');
    }
    if (isBulk) {
      var summary = Cart.getItems().map(function(i) {
        return i.qty + 'x ' + i.name + ' (' + (i.colour || 'No preference') + ') @ ' + i.price;
      }).join('%0A');
      var waMsg = 'Hi Christo! I%27d like to place a larger order:%0A' + summary + '%0A%0ATotal: %C2%A3' + finalTotal.toFixed(2);
      document.getElementById('bulkWhatsApp').href = 'https://wa.me/447435976773?text=' + waMsg;
    }
  }

  window.basketRender = render;

  window.applyCoupon = function () {
    var code = document.getElementById('couponCode').value.trim().toUpperCase();
    var errEl = document.getElementById('couponError');
    var match = COUPONS.find(function (c) { return c.code.toUpperCase() === code && c.active; });
    if (!match) {
      errEl.textContent = 'Invalid or expired code.';
      errEl.classList.add('visible');
      return;
    }
    appliedCoupon = match;
    try { localStorage.setItem(COUPON_KEY, match.code); } catch(e) {}
    errEl.textContent = '';
    errEl.classList.remove('visible');
    document.getElementById('couponInputRow').style.display = 'none';
    document.getElementById('couponApplied').style.display = 'flex';
    document.getElementById('couponAppliedText').textContent =
      '"' + match.code + '" — ' + match.description + ' applied';
    if (match.requireReason) {
      document.getElementById('couponReasonRow').style.display = 'block';
      setTimeout(function () { document.getElementById('couponReason').focus(); }, 50);
    }
    renderTotal();
  };

  window.removeCoupon = function () {
    appliedCoupon = null;
    try { localStorage.removeItem(COUPON_KEY); } catch(e) {}
    document.getElementById('couponCode').value = '';
    document.getElementById('couponInputRow').style.display = 'flex';
    document.getElementById('couponApplied').style.display = 'none';
    document.getElementById('couponReasonRow').style.display = 'none';
    document.getElementById('couponReason').value = '';
    document.getElementById('couponReasonError').textContent = '';
    renderTotal();
  };

  window.handleKeychainInput = function (id, input) {
    Cart.updateKeychainName(id, input.value);
    var estEl = document.getElementById('keychain-est-' + id);
    if (estEl) estEl.textContent = 'Est: ' + Cart.keychainPrice(input.value);
    renderTotal();
  };

  window.startCheckout = async function () {
    var totalQty = Cart.getItems().reduce(function(s, i) { return s + i.qty; }, 0);
    if (Cart.getTotal() > 30 || totalQty > 20) return; // blocked by bulk notice
    var email = document.getElementById('email').value.trim();
    var phone = document.getElementById('phone').value.trim();
    var contactError = document.getElementById('contactError');
    var payError = document.getElementById('payError');

    if (!email && !phone) {
      contactError.classList.add('visible');
      document.getElementById('email').focus();
      return;
    }

    // Validate damage reason if required
    var damageReason = '';
    if (appliedCoupon && appliedCoupon.requireReason) {
      damageReason = document.getElementById('couponReason').value.trim();
      if (!damageReason) {
        var reasonErr = document.getElementById('couponReasonError');
        reasonErr.textContent = 'Please describe why you\'re using this code.';
        reasonErr.classList.add('visible');
        document.getElementById('couponReason').focus();
        return;
      }
    }

    contactError.classList.remove('visible');
    payError.classList.remove('visible');
    payError.textContent = '';

    var btn = document.getElementById('payBtn');
    btn.disabled = true;
    btn.textContent = 'Redirecting to payment…';

    var baseNotes = document.getElementById('notes').value.trim();
    var fullNotes = damageReason ? (baseNotes ? baseNotes + '\n' : '') + '[Damage reason: ' + damageReason + ']' : baseNotes;

    try {
      var res = await fetch('/.netlify/functions/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: Cart.getItems(),
          name: document.getElementById('name').value.trim(),
          email: email,
          phone: phone,
          notes: fullNotes,
          couponCode: appliedCoupon ? appliedCoupon.code : null,
          cardFee: cardFeeAmount,
        }),
      });

      var data = await res.json();
      if (!res.ok || !data.url) throw new Error(data.error || 'Could not start payment');

      sessionStorage.setItem('lastOrder', JSON.stringify({
        items: Cart.getItems(),
        name: document.getElementById('name').value.trim(),
        email: email,
        phone: phone,
        notes: fullNotes,
      }));
      // Cart is cleared on the success page, not here — so it's preserved if the user abandons payment
      window.location.href = data.url;
    } catch (err) {
      btn.disabled = false;
      btn.textContent = 'Pay with Card';
      payError.textContent = 'Payment error: ' + err.message;
      payError.classList.add('visible');
    }
  };

  window.payAtDelivery = function () {
    var email = document.getElementById('email').value.trim();
    var phone = document.getElementById('phone').value.trim();
    var contactError = document.getElementById('contactError');

    if (!email && !phone) {
      contactError.classList.add('visible');
      document.getElementById('email').focus();
      return;
    }
    contactError.classList.remove('visible');

    document.getElementById('deliveryName').value = document.getElementById('name').value.trim();
    document.getElementById('deliveryEmail').value = email;
    document.getElementById('deliveryPhone').value = phone;
    var baseNotesDelivery = document.getElementById('notes').value.trim();
    var damageReasonDelivery = (appliedCoupon && appliedCoupon.requireReason) ? document.getElementById('couponReason').value.trim() : '';
    var fullNotesDelivery = damageReasonDelivery ? (baseNotesDelivery ? baseNotesDelivery + '\n' : '') + '[Damage reason: ' + damageReasonDelivery + ']' : baseNotesDelivery;
    document.getElementById('deliveryNotes').value = fullNotesDelivery;
    document.getElementById('deliveryItems').value = Cart.toSummaryText();
    document.getElementById('deliveryDiscount').value = appliedCoupon ? appliedCoupon.code + ' (' + appliedCoupon.description + ')' : '';

    Cart.clear();
    document.getElementById('deliveryForm').submit();
  };

  document.getElementById('email').addEventListener('input', function () {
    document.getElementById('contactError').classList.remove('visible');
  });
  document.getElementById('phone').addEventListener('input', function () {
    document.getElementById('contactError').classList.remove('visible');
  });

  // Restore saved coupon
  (function() {
    try {
      var saved = localStorage.getItem(COUPON_KEY);
      if (saved) {
        var match = COUPONS.find(function(c) { return c.code === saved && c.active; });
        if (match) {
          appliedCoupon = match;
          document.getElementById('couponInputRow').style.display = 'none';
          document.getElementById('couponApplied').style.display = 'flex';
          document.getElementById('couponAppliedText').textContent = '"' + match.code + '" — ' + match.description + ' applied';
          if (match.requireReason) {
            document.getElementById('couponReasonRow').style.display = 'block';
          }
        }
      }
    } catch(e) {}
  })();

  loadDetails();
  render();
})();

// Reset pay button if user navigates back from payment without paying
window.addEventListener('pageshow', function (e) {
  if (e.persisted) {
    var btn = document.getElementById('payBtn');
    if (btn && btn.disabled) {
      btn.disabled = false;
      btn.textContent = 'Pay with Card';
    }
  }
});
</script>
