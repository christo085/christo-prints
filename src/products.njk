---
layout: base.njk
title: "Products - Christo's Prints"
description: "Browse all 3D-printed fidget toys and practical gadgets from Christo's Prints."
activePage: products
permalink: /products/
---

<!-- Page Header -->
<div class="page-header">
  <h1>All Products</h1>
  <p>Fidget toys, practical gadgets, and more</p>
</div>

<!-- Products -->
<section class="section" style="padding-top: 0;">

  <!-- Search & Sort Row -->
  <div class="products-toolbar">
    <div class="product-search">
      <svg class="product-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="form-input product-search-input" id="productSearch" placeholder="Search products...">
    </div>
    <select class="form-input product-sort" id="productSort" aria-label="Sort products">
      <option value="default">Sort: Default</option>
      <option value="price-asc">Price: Low to High</option>
      <option value="price-desc">Price: High to Low</option>
      <option value="popular">Popular First</option>
    </select>
  </div>

  <!-- Filter Tabs -->
  <div class="category-tabs">
    <button class="tab-btn active" type="button" data-filter="all">All</button>
    <button class="tab-btn" type="button" data-filter="fidget">Fidget Toys</button>
    <button class="tab-btn" type="button" data-filter="flexi">Flexi Prints</button>
    <button class="tab-btn" type="button" data-filter="gadget">Gadgets</button>
    <button class="tab-btn" type="button" data-filter="decor">Decor</button>
  </div>

  <!-- Seasonal banner(s) -->
  {%- set SEASONAL_BADGES = ["Easter", "Halloween", "Christmas", "Spring", "Other"] %}
  {%- set activeBadges = [] %}
  {%- for item in events.seasonal %}
    {%- if item.badge and item.badge not in activeBadges %}
      {%- set activeBadges = activeBadges.concat([item.badge]) %}
    {%- endif %}
  {%- endfor %}
  {%- for item in products.items %}
    {%- if item.badge and item.badge in SEASONAL_BADGES and item.badge not in activeBadges %}
      {%- set activeBadges = activeBadges.concat([item.badge]) %}
    {%- endif %}
  {%- endfor %}
  {%- for badge in activeBadges %}
  <a href="/events/?open={{ badge }}" class="seasonal-products-banner">
    <span class="seasonal-products-banner-label">{{ badge }} Collection</span>
    <span>See our seasonal specials &#8594;</span>
  </a>
  {%- endfor %}

  <!-- No Results State -->
  <div class="no-results" id="noResults" hidden>
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    <h3>No products found</h3>
    <p>Try a different search term or category.</p>
    <button class="btn btn-secondary" onclick="clearSearch()" style="margin-top:12px;">Clear search</button>
  </div>

  <div class="product-grid" id="productGrid">
    {%- for product in products.items %}
    <div class="product-card" data-category="{{ product.category }}" data-badge="{{ product.badge }}" data-keywords="{{ product.name | lower }} {{ product.description | lower }} {{ product.category }}" data-price="{{ product.price | replace('£','') }}" data-popular="{{ product.popular }}">
      <a href="/products/{{ product.name | slug }}/" class="product-card-img-link" tabindex="-1" aria-hidden="true">
        <div class="product-card-img">
          <img src="/{{ product.image }}" alt="{{ product.name }}" loading="lazy">
          {%- if product.badge %}
          <span class="product-card-badge{% if product.badge == 'Trending' %} badge-trending{% endif %}">{{ product.badge }}</span>
          {%- endif %}
        </div>
      </a>
      <div class="product-card-body">
        <a href="/products/{{ product.name | slug }}/" class="product-card-title-link">
          <h3>{{ product.name }}</h3>
        </a>
        <p class="description">{{ product.description }}</p>
        <div class="product-card-footer">
          <span class="price">{{ product.price }}</span>
          <div class="btn-group">
            <a href="/products/{{ product.name | slug }}/" class="btn btn-secondary btn-small" aria-label="View {{ product.name }} details">Details</a>
            <button class="btn btn-primary btn-small btn-add-to-cart"
              data-name="{{ product.name }}" data-price="{{ product.price }}" data-type="product"
              onclick="Cart.addItem(this.dataset.name, this.dataset.price, this.dataset.type); Cart.flashAdded(this);"
              aria-label="Add {{ product.name }} to basket">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="9" y1="6" x2="15" y2="6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
    {%- endfor %}
    {%- for item in events.seasonal %}
    <div class="product-card" data-category="seasonal" data-keywords="{{ item.name | lower }} {{ item.description | lower }} seasonal" data-price="{{ item.price | replace('£','') }}" data-popular="false" style="display:none">
      {%- if item.image %}
      <div class="product-card-img">
        <img src="/{{ item.image }}" alt="{{ item.name }}" loading="lazy">
        {%- if item.badge %}
        <span class="product-card-badge">{{ item.badge }}</span>
        {%- endif %}
      </div>
      {%- endif %}
      <div class="product-card-body">
        <h3>{{ item.name }}</h3>
        <p class="description">{{ item.description }}</p>
        <div class="product-card-footer">
          <span class="price">{{ item.price }}</span>
          <button class="btn btn-primary btn-small btn-add-to-cart"
            data-name="{{ item.name }}" data-price="{{ item.price }}" data-type="seasonal"
            onclick="Cart.addItem(this.dataset.name, this.dataset.price, this.dataset.type); Cart.flashAdded(this);"
            aria-label="Add {{ item.name }} to basket">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="9" y1="6" x2="15" y2="6"/></svg>
          </button>
        </div>
      </div>
    </div>
    {%- endfor %}
  </div>
</section>

<!-- CTA -->
<section class="section" style="padding-top: 0;">
  <div class="cta-banner">
    <h2>Don't See What You Want?</h2>
    <p>Submit a custom print request and we'll make it for you.</p>
    <a href="/custom/" class="btn btn-primary">Request Custom Print &#8594;</a>
  </div>
</section>

<script>
  (function () {
    var tabs = document.querySelectorAll('.tab-btn');
    var searchInput = document.getElementById('productSearch');
    var sortSelect = document.getElementById('productSort');
    var grid = document.getElementById('productGrid');
    var noResults = document.getElementById('noResults');
    var activeFilter = 'all';

    function getCards() {
      return Array.from(grid.querySelectorAll('.product-card'));
    }

    function filterAndSort() {
      var query = searchInput.value.toLowerCase().trim();
      var sort = sortSelect.value;
      var cards = getCards();
      var visible = [];

      cards.forEach(function (card) {
        var cat = card.dataset.category;
        var keywords = card.dataset.keywords || '';
        var catMatch;

        if (activeFilter === 'all') {
          catMatch = cat !== 'seasonal';
        } else {
          catMatch = cat === activeFilter;
        }

        var searchMatch = !query || keywords.indexOf(query) !== -1;
        var show = catMatch && searchMatch;
        card.style.display = show ? '' : 'none';
        if (show) visible.push(card);
      });

      // Sort visible cards by reordering in DOM
      if (sort !== 'default' && visible.length > 1) {
        visible.sort(function (a, b) {
          if (sort === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
          if (sort === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
          if (sort === 'popular') return (b.dataset.popular === 'true' ? 1 : 0) - (a.dataset.popular === 'true' ? 1 : 0);
          return 0;
        });
        visible.forEach(function (card) { grid.appendChild(card); });
      }

      noResults.hidden = visible.length > 0;
    }

    window.clearSearch = function () {
      searchInput.value = '';
      filterAndSort();
      searchInput.focus();
    };

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        tabs.forEach(function (t) { t.classList.remove('active'); });
        tab.classList.add('active');
        activeFilter = tab.dataset.filter;
        filterAndSort();
      });
    });

    searchInput.addEventListener('input', filterAndSort);
    sortSelect.addEventListener('change', filterAndSort);

    // Auto-select tab from ?cat= URL param
    var urlCat = new URLSearchParams(window.location.search).get('cat');
    if (urlCat) {
      var matchTab = Array.from(tabs).find(function (t) { return t.dataset.filter === urlCat; });
      if (matchTab) matchTab.click();
    } else {
      filterAndSort();
    }
  })();
</script>
