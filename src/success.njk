---
layout: base.njk
title: "Order Placed - Christo's Prints"
description: "Thank you for your order from Christo's Prints."
permalink: /success/
---

<div class="page-header">
  <h1>Order Placed!</h1>
</div>

<section class="section" style="padding-top: 0;">
  <div class="cart-success">
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
      <polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <h2>Thanks for your order!</h2>
    <p>We'll get your prints ready and be in touch to arrange collection.</p>

    <div class="success-summary" id="successSummary" style="display:none;">
      <div class="success-summary-items" id="successItems"></div>
      <div class="success-summary-total" id="successTotal"></div>
    </div>

    <a href="/products/" class="btn btn-primary" style="margin-top: 24px;">Continue Browsing</a>
  </div>
</section>

<!-- Hidden Netlify form for Square order email notification -->
<form name="square-order" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="squareOrderForm" hidden>
  <input type="hidden" name="form-name" value="square-order">
  <input type="hidden" name="bot-field">
  <input type="hidden" name="payment" value="Square (card)">
  <input type="hidden" name="customer-name" id="soName">
  <input type="hidden" name="email" id="soEmail">
  <input type="hidden" name="phone" id="soPhone">
  <input type="hidden" name="notes" id="soNotes">
  <input type="hidden" name="cart-items" id="soItems">
</form>

<script>
(function () {
  var raw = sessionStorage.getItem('lastOrder');
  if (!raw) return;
  try {
    sessionStorage.removeItem('lastOrder');
    Cart.clear(); // Payment confirmed — now safe to clear the cart
    var order = JSON.parse(raw);
    var items = order.items || [];

    var itemSummary = items.map(function (i) {
      var line = i.name + ' x' + i.qty + ' @ ' + i.price;
      if (i.colour && i.colour !== 'No preference') line += ' (' + i.colour + ')';
      if (i.keychainName) line += ' — Name: ' + i.keychainName;
      return line;
    }).join('\n');

    // Submit Netlify notification form via fetch (no page navigation)
    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        'form-name': 'square-order',
        'bot-field': '',
        'payment': 'Square (card)',
        'customer-name': order.name || '',
        'email': order.email || '',
        'phone': order.phone || '',
        'notes': order.notes || '',
        'cart-items': itemSummary
      }).toString()
    }).catch(function () {});

    // Render order summary
    if (items.length > 0) {
      var itemsEl = document.getElementById('successItems');
      itemsEl.innerHTML = items.map(function (i) {
        var label = i.name;
        if (i.colour && i.colour !== 'No preference') label += ' <span class="success-item-colour">(' + i.colour + ')</span>';
        if (i.keychainName) label += ' <span class="success-item-colour">— ' + i.keychainName + '</span>';
        var price = parseFloat((i.price || '0').replace('£', '')) || 0;
        return '<div class="success-item">' +
          '<span class="success-item-name">' + label + '</span>' +
          '<span class="success-item-qty">x' + i.qty + '</span>' +
          '<span class="success-item-price">£' + (price * i.qty).toFixed(2) + '</span>' +
        '</div>';
      }).join('');

      var total = items.reduce(function (sum, i) {
        return sum + ((parseFloat((i.price || '0').replace('£', '')) || 0) * i.qty);
      }, 0);

      var totalEl = document.getElementById('successTotal');
      totalEl.innerHTML = '<span>Total paid</span><span>£' + total.toFixed(2) + '</span>';

      document.getElementById('successSummary').style.display = 'block';
    }
  } catch (e) {}
})();
</script>
