<!-- Form -->
<section class="section" style="padding-top: 0;">

  <!-- Success State -->
  <div class="cart-success" id="customSuccess" hidden>
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
      <polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <h2>Request submitted!</h2>
    <p>Thanks for your custom print idea. We'll be in touch soon to discuss the details.</p>
    <a href="/products/" class="btn btn-primary" style="margin-top: 16px;">Browse Products</a>
  </div>

  <!-- Commercial callout -->
  <div class="cta-banner custom-biz-callout" id="customFormWrapper">
    <p class="custom-biz-label">For businesses</p>
    <h3>We work on commercial projects too</h3>
    <p>We've printed modular hydroponic systems, specialist components, and custom parts for local businesses. If you have a brief, a drawing, or just an idea, get in touch and we'll figure out the rest.</p>
  </div>

  <!-- Form -->
  <div class="form-container" id="customFormContainer">
    <form name="custom-print" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/custom/?success=true" id="customForm">
      <input type="hidden" name="form-name" value="custom-print">
      <p class="visually-hidden"><label>Don't fill this in: <input name="bot-field"></label></p>

      <div class="form-group">
        <label class="form-label" for="name">Name</label>
        <input class="form-input" type="text" id="name" name="name" placeholder="Your name" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com">
        </div>
        <div class="form-group">
          <label class="form-label" for="phone">Phone</label>
          <input class="form-input" type="tel" id="phone" name="phone" placeholder="07xxx xxxxxx">
        </div>
      </div>
      <p class="form-hint">Please provide at least an email or phone number.</p>
      <p class="form-error" id="contactError">Please enter an email address or phone number so we can reach you.</p>

      <div class="form-group">
        <label class="form-label" for="description">What would you like printed? <span style="color: var(--text-muted); font-weight: 400;">*</span></label>
        <textarea class="form-textarea" id="description" name="description" placeholder="Describe your custom print idea — what it is, how big, what it's for, etc." required style="min-height: 120px;"></textarea>
      </div>

      <div class="form-group">
        <label class="form-label" for="quantity">Quantity</label>
        <input class="form-input" type="number" id="quantity" name="quantity" min="1" placeholder="How many do you need? (leave blank if unsure)">
      </div>

      <div class="form-group">
        <label class="form-label" for="notes">Anything else?</label>
        <textarea class="form-textarea" id="notes" name="notes" placeholder="Preferred colours, deadline, budget, or any other details"></textarea>
      </div>

      <button type="submit" class="btn btn-primary btn-large">Submit Request</button>
    </form>
  </div>

</section>

<style>
.custom-steps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
}

.custom-step-card {
  text-align: center;
}

.custom-step-number {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--accent);
  margin: 0 auto 12px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--accent-dim);
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-biz-callout {
  max-width: 600px;
  margin: 0 auto 32px;
  text-align: left;
}

.custom-biz-label {
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--accent);
  margin-bottom: 8px !important;
}

.custom-biz-callout h3 {
  margin: 0 0 8px;
  font-size: 1.2rem;
}

.custom-biz-callout > p:last-child {
  margin: 0;
  color: var(--text-secondary);
}
</style>

<script>
(function () {
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('customSuccess').hidden = false;
    document.getElementById('customFormWrapper').hidden = true;
    document.getElementById('customFormContainer').hidden = true;
    return;
  }

  var form = document.getElementById('customForm');
  form.addEventListener('submit', function (e) {
    var email = document.getElementById('email').value.trim();
    var phone = document.getElementById('phone').value.trim();
    var errorEl = document.getElementById('contactError');

    if (!email && !phone) {
      e.preventDefault();
      errorEl.classList.add('visible');
      document.getElementById('email').focus();
      return;
    }
    errorEl.classList.remove('visible');
  });

  document.getElementById('email').addEventListener('input', function () {
    document.getElementById('contactError').classList.remove('visible');
  });
  document.getElementById('phone').addEventListener('input', function () {
    document.getElementById('contactError').classList.remove('visible');
  });
})();
</script>
