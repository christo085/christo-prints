<style>
/* Page header tweak for toggle */
.custom-page-header {
  padding-bottom: 0;
}

/* Toggle */
.custom-toggle-wrap {
  display: flex;
  justify-content: center;
  margin-top: 28px;
  padding-bottom: 48px;
}

.custom-toggle {
  display: inline-flex;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 4px;
  gap: 4px;
}

.custom-toggle-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 10px 24px;
  border-radius: 100px;
  border: none;
  background: none;
  color: var(--text-secondary);
  font-family: inherit;
  font-size: 0.92rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.custom-toggle-btn.active {
  background: var(--accent);
  color: var(--bg-primary);
  font-weight: 600;
}

.custom-toggle-btn:not(.active):hover {
  color: var(--text-primary);
}

/* Step cards */
.custom-steps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

@media (max-width: 768px) {
  .custom-steps-grid {
    grid-template-columns: 1fr;
  }
}

.custom-step-card {
  text-align: center;
}

.custom-step-number {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--accent);
  margin: 0 auto 12px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--accent-dim);
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-contact-alt {
  margin-top: 16px;
  text-align: center;
  font-size: 0.88rem;
  color: var(--text-muted);
}

.form-contact-alt a {
  color: var(--text-secondary);
}

.form-contact-alt a:hover {
  color: var(--accent);
}

/* Optional label */
.form-label-optional {
  color: var(--text-muted);
  font-weight: 400;
  font-size: 0.85em;
}
</style>

<script>
(function () {
  var pageLoadTime = Date.now();
  var btns = document.querySelectorAll('.custom-toggle-btn');
  var tabs = document.querySelectorAll('.custom-tab');

  function switchTab(name) {
    btns.forEach(function (btn) {
      var active = btn.dataset.tab === name;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    tabs.forEach(function (tab) {
      tab.hidden = tab.id !== 'tab-' + name;
    });
    var url = new URL(window.location);
    url.searchParams.set('tab', name);
    history.replaceState(null, '', url);
  }

  btns.forEach(function (btn) {
    btn.addEventListener('click', function () { switchTab(this.dataset.tab); });
  });

  // Handle success states
  var params = new URLSearchParams(window.location.search);
  var success = params.get('success');
  if (success === 'personal') {
    switchTab('personal');
    document.getElementById('personalSuccess').hidden = false;
    document.getElementById('personalFormContainer').hidden = true;
  } else if (success === 'business') {
    switchTab('business');
    document.getElementById('bizSuccess').hidden = false;
    document.getElementById('bizFormContainer').hidden = true;
  } else {
    // Check tab param on load
    var tabParam = params.get('tab');
    if (tabParam === 'business') switchTab('business');
  }

  // Personal form validation
  var personalForm = document.getElementById('personalForm');
  var personalEmailEl = document.getElementById('p-email');
  var personalPhoneEl = document.getElementById('p-phone');
  var personalErr = document.getElementById('personalContactError');

  personalForm.addEventListener('submit', function (e) {
    if (Date.now() - pageLoadTime < 3000) { e.preventDefault(); return; }
    if (!personalEmailEl.value.trim() && !personalPhoneEl.value.trim()) {
      e.preventDefault();
      personalErr.classList.add('visible');
      personalEmailEl.focus();
    } else {
      personalErr.classList.remove('visible');
    }
  });
  personalEmailEl.addEventListener('input', function () { personalErr.classList.remove('visible'); });
  personalPhoneEl.addEventListener('input', function () { personalErr.classList.remove('visible'); });

  // Business form validation
  var bizForm = document.getElementById('bizForm');
  var bizEmailEl = document.getElementById('b-email');
  var bizPhoneEl = document.getElementById('b-phone');
  var bizErr = document.getElementById('bizContactError');

  bizForm.addEventListener('submit', function (e) {
    if (Date.now() - pageLoadTime < 3000) { e.preventDefault(); return; }
    if (!bizEmailEl.value.trim() && !bizPhoneEl.value.trim()) {
      e.preventDefault();
      bizErr.classList.add('visible');
      bizEmailEl.focus();
    } else {
      bizErr.classList.remove('visible');
    }
  });
  bizEmailEl.addEventListener('input', function () { bizErr.classList.remove('visible'); });
  bizPhoneEl.addEventListener('input', function () { bizErr.classList.remove('visible'); });
})();
</script>
