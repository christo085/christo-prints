---
layout: base.njk
title: "Colours - Christo's Prints"
description: "Choose from a wide range of filament colours for your 3D-printed products from Christo's Prints."
activePage: colours
permalink: /colours/
---

<!-- Page Header -->
<div class="page-header">
  <h1>Colours</h1>
  <p>Pick your favourite colour for any product</p>
</div>

<!-- Standard Colours -->
<section class="section" style="padding-top: 0;">
  <div class="section-header">
    <h2>Standard Colours</h2>
    <p>All products can be printed in any of these colours. Just let us know when you order.</p>
    <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 6px;">Tap a colour to see example prints</p>
  </div>

  <div class="colour-grid" id="colourGrid">
    <!-- Standard colours populated via JS -->
  </div>
</section>

<!-- Special Colours -->
<section class="section" style="padding-top: 0;">
  <div class="section-header">
    <h2>Special Colours</h2>
    <p>Premium and unique filaments for something extra</p>
    <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 6px;">Tap a colour to see example prints</p>
  </div>

  <div class="colour-grid" id="specialColourGrid">
    <!-- Special colours populated via JS -->
  </div>

  <p style="text-align: center; color: var(--text-secondary); margin-top: 32px; font-size: 0.9rem;">
    Colours shown are approximate. Actual shades may vary slightly due to printing and screen differences.
  </p>
</section>

<!-- CTA -->
<section class="section" style="padding-top: 0;">
  <div class="cta-banner">
    <h2>Need a Specific Colour?</h2>
    <p>If you don't see the colour you want, get in touch and we'll see what we can do.</p>
    <a href="/contact/" class="btn btn-primary">Contact Us &#8594;</a>
  </div>
</section>

<!-- Colour Preview Modal -->
<div id="colourModal" role="dialog" aria-modal="true" aria-labelledby="colourModalName"
  style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.6); backdrop-filter:blur(6px); align-items:center; justify-content:center; padding:16px;">
  <div id="colourModalCard"
    style="background:var(--surface); border-radius:20px; max-width:560px; width:100%; max-height:85vh; overflow:hidden; box-shadow:0 32px 64px rgba(0,0,0,0.4); display:flex; flex-direction:column;">

    <!-- Colour header -->
    <div id="colourModalHdr" style="position:relative; min-height:120px; display:flex; flex-direction:column; justify-content:flex-end; padding:20px 24px; flex-shrink:0; border-radius:20px 20px 0 0;">
      <div id="colourModalHdrBg" style="position:absolute; inset:0; border-radius:20px 20px 0 0;"></div>
      <div style="position:absolute; inset:0; border-radius:20px 20px 0 0; background:linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);"></div>
      <button onclick="closeColourModal()" aria-label="Close"
        style="position:absolute; top:14px; right:14px; background:rgba(0,0,0,0.3); border:none; color:#fff; width:34px; height:34px; border-radius:50%; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center; line-height:1; z-index:1;">&#215;</button>
      <div style="position:relative; z-index:1;">
        <h2 id="colourModalName" style="margin:0; color:#fff; font-size:1.5rem; text-shadow:0 2px 8px rgba(0,0,0,0.5);"></h2>
        <p id="colourModalDesc" style="margin:4px 0 0; color:rgba(255,255,255,0.88); font-size:0.875rem; text-shadow:0 1px 4px rgba(0,0,0,0.4);"></p>
      </div>
    </div>

    <!-- Product examples -->
    <div style="padding:20px 24px 24px; overflow-y:auto; flex:1;">
      <p style="margin:0 0 14px; color:var(--text-secondary); font-size:0.875rem; font-weight:500;">Example prints available in this colour</p>
      <div id="colourModalProducts" style="display:grid; grid-template-columns:repeat(3, 1fr); gap:10px;"></div>
      <p style="margin:16px 0 0; font-size:0.8rem; color:var(--text-secondary); text-align:center;">All products can be printed in any colour — just mention it when you order.</p>
    </div>
  </div>
</div>

<style>
@keyframes colourModalIn {
  from { opacity: 0; transform: translateY(16px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
#colourModalCard { animation: colourModalIn 0.22s cubic-bezier(0.22, 1, 0.36, 1); }
.colour-swatch {
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
  position: relative;
}
.colour-swatch::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  opacity: 0;
  transition: opacity 0.18s;
  background: rgba(255,255,255,0.12);
}
.colour-swatch:hover { transform: translateY(-5px) scale(1.06); box-shadow: 0 10px 28px rgba(0,0,0,0.22); }
.colour-swatch:hover::after { opacity: 1; }
.colour-swatch:active { transform: scale(0.98); }
</style>

<script>
  var standardColours = {{ colours.standard | dump | safe }};
  var specialColours = {{ colours.special | dump | safe }};
  var allProducts = {{ products.items | dump | safe }};

  var exampleProducts = allProducts.filter(function(p) { return p.image; }).slice(0, 6);

  function renderSwatches(colours, gridId) {
    var grid = document.getElementById(gridId);
    colours.forEach(function (c) {
      var swatch = document.createElement('div');
      swatch.className = 'colour-swatch';
      swatch.style.background = c.hex;
      if (c.description) swatch.title = c.description;
      swatch.innerHTML = '<span>' + c.name + '</span>';
      swatch.addEventListener('click', function () { openColourModal(c); });
      grid.appendChild(swatch);
    });
  }

  function openColourModal(colour) {
    var modal = document.getElementById('colourModal');
    var hdrBg = document.getElementById('colourModalHdrBg');
    var nameEl = document.getElementById('colourModalName');
    var descEl = document.getElementById('colourModalDesc');
    var productsEl = document.getElementById('colourModalProducts');

    hdrBg.style.background = colour.hex;
    nameEl.textContent = colour.name;
    descEl.textContent = colour.description || 'Available on all products';

    productsEl.innerHTML = '';
    exampleProducts.forEach(function (p) {
      var item = document.createElement('div');
      item.style.cssText = 'border-radius:10px; overflow:hidden; background:var(--bg); border:1px solid var(--border);';
      item.innerHTML =
        '<img src="/' + p.image + '" alt="' + p.name + '" loading="lazy" style="width:100%; aspect-ratio:1/1; object-fit:cover; display:block;">' +
        '<div style="padding:6px 8px; font-size:0.78rem; font-weight:500; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">' + p.name + '</div>';
      productsEl.appendChild(item);
    });

    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    var card = document.getElementById('colourModalCard');
    card.style.animation = 'none';
    card.offsetHeight;
    card.style.animation = '';
  }

  function closeColourModal() {
    document.getElementById('colourModal').style.display = 'none';
    document.body.style.overflow = '';
  }

  document.getElementById('colourModal').addEventListener('click', function (e) {
    if (e.target === this) closeColourModal();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeColourModal();
  });

  renderSwatches(standardColours, 'colourGrid');
  renderSwatches(specialColours, 'specialColourGrid');
</script>
